[Desktop Entry]
Name=RGB GPUs Teaming
Comment=Launch applications with RGB GPUs Teaming
Exec=/opt/rgb-gpus-teaming/manual-setup.sh %F
TryExec=/opt/rgb-gpus-teaming/manual-setup.sh
Icon=/opt/rgb-gpus-teaming/icon/manual-setup.png
Terminal=true
Type=Application
Categories=Utility;
StartupNotify=true
Actions=RunAsRoot;

[Desktop Action RunAsRoot]
Name=Run as root
Exec=pkexec /opt/rgb-gpus-teaming/manual-setup.sh