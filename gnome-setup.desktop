[Desktop Entry]
Name=RGB GPUs Teaming (GNOME)
Comment=Configure applications with RGB GPUs Teaming
Exec=/opt/rgb-gpus-teaming/gnome-setup.sh %F
TryExec=/opt/rgb-gpus-teaming/gnome-setup.sh
Icon=/opt/rgb-gpus-teaming/icon/gnome-setup.ico
Terminal=true
Type=Application
Categories=Utility;
StartupNotify=true
Actions=RunAsRoot;

[Desktop Action RunAsRoot]
Name=Run as root
Exec=pkexec /opt/rgb-gpus-teaming/gnome-setup.sh